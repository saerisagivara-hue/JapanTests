{
  "name": "japanese-trainer",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "author": "Japanese Trainer",
  "description": "Тренажёр японского языка — видео-уроки JLPT N5–N1 с аниме",
  "scripts": {
    "dev": "next dev",
    "dev:video": "node scripts/dev-video-server.js",
    "dev:stop": "taskkill /F /IM node.exe 2>nul || echo Готово",
    "dev:open": "node scripts/dev-with-open.js",
    "dev:https": "node server.js",
    "cert": "node scripts/create-cert.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cap:sync": "npx cap sync",
    "android": "npm run build && npx cap sync android && npx cap open android",
    "desktop": "npm run build && npx electron electron/main.js",
    "deskt": "npm run desktop",
    "ios": "npm run build && npx cap sync ios && npx cap open ios",
    "predist": "npm run build",
    "dist": "electron-builder --win --dir & node scripts/postdist.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@tailwindcss/postcss": "^4",
    "express": "^5.2.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@capacitor/ios": "^8.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "ffmpeg-static": "^5.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.japanese-trainer.app",
    "productName": "Japanese Trainer",
    "directories": {
      "output": "C:\\japanese-trainer-dist"
    },
    "files": [
      "electron/**/*",
      "scripts/local-video-dirs.cjs",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/express/**/*",
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraResources": [
      {
        "from": "C:\\Users\\saeri\\Downloads\\[FLE] Boku no Hero Academia - S01v2 (BD 1080p HEVC Opus) [Dual Audio]",
        "to": "videos/mha",
        "filter": [
          "*.mkv"
        ]
      },
      {
        "from": "C:\\Users\\saeri\\Downloads\\[Erai-raws] Beastars - 01 ~ 12 [1080p][Multiple Subtitle]",
        "to": "videos/beastars",
        "filter": [
          "*.mkv"
        ]
      },
      {
        "from": "C:\\Users\\saeri\\Downloads\\[Erai-raws] Jujutsu Kaisen - 01 ~ 24 [1080p][Multiple Subtitle]",
        "to": "videos/jjk",
        "filter": [
          "*.mkv"
        ]
      },
      {
        "from": "C:\\Users\\saeri\\Downloads\\[Erai-raws] Kimetsu no Yaiba - 01 ~ 26 [1080p][HEVC][Multiple Subtitle]",
        "to": "videos/kny",
        "filter": [
          "*.mkv"
        ]
      }
    ],
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    }
  }
}
